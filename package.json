{
  "name": "@voiden/runner",
  "version": "0.1.0",
  "description": "CLI runner for .void files — execute REST, WebSocket, and gRPC requests headlessly",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "voiden-runner": "./dist/index.js"
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.13",
    "@voiden/core-extensions": "https://github.com/VoidenHQ/core-plugins/releases/download/v1.0.0/voiden-core-extensions-1.0.0.tgz",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ws": "^8.17.0",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.10",
    "tsx": "^4.15.0",
    "typescript": "^5.5.3"
  }
}
